<?xml version="1.0"?>
<!-- ============================================================
     tarantula_core：标准演示配置 = 底盘模块 + LiDAR 载荷。
     本体定义在 tarantula_chassis.xacro（模块化底盘，单一事实来源），
     本文件只做实例化与载荷挂载——体现"产品是底盘，整车是配置"。
     仿真器无关：无 <gazebo> 标签、插件、ros2_control（适配层的事）。

     Isaac Lab 导入：
       xacro tarantula_core.urdf.xacro > tarantula.urdf          # 带 LiDAR
       xacro tarantula_core.urdf.xacro lidar:=false > bare.urdf  # 裸底盘
       xacro tarantula_core.urdf.xacro wheel_collision:=cylinder # 圆柱 collision A/B
     悬挂执行器等效参数 kp=120 Nm/rad、kd=8 Nms/rad 在 Isaac 中映射为
     关节 drive 的 stiffness/damping；Gazebo 部署侧由策略节点显式计算
     受限 PD 力矩，不再依赖 Gazebo-only joint spring。
     ============================================================ -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="tarantula">

  <xacro:include filename="$(find tarantula_description)/urdf/tarantula_chassis.xacro"/>

  <xacro:arg name="wheel_collision" default="sphere"/>
  <xacro:tarantula_chassis prefix="" wheel_collision="$(arg wheel_collision)"/>

  <!-- ============ LiDAR 载荷（可选，挂 payload_mount） ============ -->
  <xacro:arg name="lidar" default="true"/>
  <xacro:if value="$(arg lidar)">
    <link name="lidar_link">
      <visual>
        <geometry><cylinder radius="0.045" length="0.06"/></geometry>
        <xacro:mat_tire/>
      </visual>
      <visual>  <!-- 支撑柱 -->
        <origin xyz="0 0 -0.06"/>
        <geometry><cylinder radius="0.02" length="0.06"/></geometry>
        <xacro:mat_hub/>
      </visual>
      <inertial>
        <mass value="0.2"/>
        <xacro:cylinder_inertia m="0.2" r="0.045" h="0.06"/>
      </inertial>
    </link>
    <joint name="lidar_joint" type="fixed">
      <parent link="payload_mount"/>
      <child link="lidar_link"/>
      <!-- 安装板顶面(0.092) + 0.078 = 0.17 -->
      <origin xyz="0.22 0 0.078"/>
    </joint>
  </xacro:if>

</robot>
